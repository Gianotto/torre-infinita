# ════════════════════════════════════════════════════════════════
# Nginx config — Torre Infinita
# ────────────────────────────────────────────────────────────────
# Salve em: /etc/nginx/sites-available/torre
# Ative com:
#   sudo ln -s /etc/nginx/sites-available/torre /etc/nginx/sites-enabled/
#   sudo nginx -t
#   sudo systemctl reload nginx
#
# Antes de habilitar HTTPS, rode:
#   sudo certbot --nginx -d torre.seudominio.com
# ════════════════════════════════════════════════════════════════

# Rate limit zone — protege contra flood na API
limit_req_zone $binary_remote_addr zone=torre_api:10m rate=10r/s;

# ─── HTTP → HTTPS redirect ─────────────────────────────────────
server {
    listen 80;
    listen [::]:80;
    server_name torre.seudominio.com;

    # Let's Encrypt usa esse path para validação
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# ─── HTTPS principal ───────────────────────────────────────────
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name torre.seudominio.com;

    # ── Certificados (certbot preenche automaticamente) ──
    ssl_certificate     /etc/letsencrypt/live/torre.seudominio.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/torre.seudominio.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

    # ── Logs ──
    access_log /var/log/nginx/torre-access.log;
    error_log  /var/log/nginx/torre-error.log;

    # ── Headers de segurança ──
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "no-referrer-when-downgrade" always;
    add_header Strict-Transport-Security "max-age=31536000" always;

    # ── Limites de upload (jogo manda JSON pequeno) ──
    client_max_body_size 16k;

    # ── API → Node.js (com rate limit) ──
    location /api/ {
        limit_req zone=torre_api burst=20 nodelay;

        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # timeouts curtos — API é rápida
        proxy_connect_timeout 5s;
        proxy_send_timeout    10s;
        proxy_read_timeout    10s;

        # sem cache para a API
        proxy_cache_bypass $http_upgrade;
        add_header Cache-Control "no-store" always;
    }

    # ── Jogo (HTML/CSS/JS estático) ──
    # Opção A: deixar o Node servir tudo (mais simples)
    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # ── Opção B (alternativa, mais rápida): servir o HTML direto pelo nginx ──
    # Comente o "location /" acima e descomente isto para melhor performance.
    # Aponta o nginx direto para o public/ do projeto:
    #
    # location / {
    #     root /var/www/torre/public;
    #     try_files $uri $uri/ /index.html;
    #     expires 1h;
    #     add_header Cache-Control "public, max-age=3600";
    # }
    #
    # # API ainda vai pelo proxy
    # # (deixa o bloco location /api/ acima do mesmo jeito)
}
